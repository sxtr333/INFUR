# API
API_HOST=0.0.0.0
API_PORT=8080

# Ключ доступа к /v1/* (не Ollama!).
# Пусто = без авторизации (удобно для локального демо).
# Пример для «прод»-режима:  API_KEY=sxtr333-infer-demo
# Тогда в curl:  -H "X-API-Key: sxtr333-infer-demo"
API_KEY=

# Ollama (GPU inference)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=darkidol-russian:latest
OLLAMA_GPU_LAYERS=999
OLLAMA_NUM_PARALLEL=1
OLLAMA_REQUEST_TIMEOUT_SEC=120

# Worker
WORKER_POLL_SEC=0.5
WORKER_BATCH_SIZE=4
WORKER_MAX_RETRIES=3
JOB_TTL_HOURS=72

# CPU cap (never above 75 on this machine)
CPU_LIMIT_PCT=70
CUDA_DEVICE_ID=0

# Queue: sqlite (default) or redis
QUEUE_BACKEND=sqlite
REDIS_URL=redis://127.0.0.1:6379/0

# Storage
DB_PATH=data/infer_hub.db

# Rate limit
RATE_LIMIT_RPM=60
